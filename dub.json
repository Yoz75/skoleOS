{
    "description": "A \"Hello World\" UEFI application with a crooked spine",

    "name": "skoleos",

    "authors": [
        "yoz75"
    ],

    "license": "MIT",
    "copyright": "Copyright © 2026, yoz75",

    "dependencies": {
        "uefi-d": "~>0.0.4"
    },

    "targetType": "executable",
    "targetName": "BOOTX64",
    "targetPath": "./bin/EFI/BOOT/",

    "dflags": [
        "--betterC",
        "-nogc",
        "--boundscheck=off",
        "--defaultlib=",
        "--debuglib=",
        "-code-model=large"
    ],

    "lflags": [
        "/SUBSYSTEM:EFI_APPLICATION",
        "/ENTRY:efi_main"
    ]
}